{
  "cli": {
    "version": ">= 7.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "_base": {
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://verified-transcript.preview.emergentagent.com"
      }
    },
    "development": {
      "extends": "_base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "extends": "_base",
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false, "resourceClass": "m-medium" },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://verified-transcript.preview.emergentagent.com",
        "EXPO_PUBLIC_IDME_ENV": "sandbox"
      }
    },
    "production": {
      "extends": "_base",
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://api.oneclicktranscript.com",
        "EXPO_PUBLIC_IDME_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ProTourSmartCycling@gmail.com",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-store-service-account.json",
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
